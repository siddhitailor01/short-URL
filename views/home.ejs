<!doctype html>
<html lang="en">
<head>
    <title>SnapLink Pro | Next-Gen URL Shortener</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --bg-dark: #0f172a;
            --card-bg: #ffffff;
        }

        body {
            background-color: #f8fafc;
            background-image: radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%), 
                              radial-gradient(at 100% 100%, rgba(168, 85, 247, 0.15) 0px, transparent 50%);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            color: #1e293b;
            padding: 40px 0;
        }

        .main-container {
            max-width: 900px;
            margin: auto;
            padding: 20px;
        }

        .header-section {
            margin-bottom: 50px;
        }

       .brand-name {
    font-weight: 800;
    font-size: 2.5rem;
    color: #a585f7;
    display: inline-block;
    /* border-bottom: 4px solid; */
    /* border-image: linear-gradient(to right, #6366f1, #a585f7) 1; */
}
        .premium-card {
            background: var(--card-bg);
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        }

        .url-input-group {
            position: relative;
            background: #f1f5f9;
            padding: 8px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .url-input-group:focus-within {
            background: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        .url-input-group input {
            background: transparent;
            border: none;
            padding: 12px 20px;
            font-size: 1.1rem;
            width: 100%;
            outline: none;
        }

        .btn-premium {
            background: var(--primary);
            color: white;
            border-radius: 12px;
            padding: 12px 28px;
            font-weight: 600;
            border: none;
            transition: all 0.2s ease;
        }

        .btn-premium:hover {
            background: var(--primary-hover);
            transform: scale(1.02);
        }

        .result-pill {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .short-url-text {
            color: #166534;
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
        }

        /* Table Styling */
        .analytics-title {
            font-weight: 700;
            margin-top: 50px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .custom-table {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }

        .custom-table thead {
            background: #f8fafc;
        }

        .custom-table th {
            padding: 15px 20px;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            border-bottom: 1px solid #e2e8f0;
        }

        .custom-table td {
            padding: 18px 20px;
            vertical-align: middle;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
        }

        .id-badge {
            background: #eef2ff;
            color: #4338ca;
            padding: 4px 10px;
            border-radius: 6px;
            font-family: monospace;
            font-weight: 600;
        }

        .click-count {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-weight: 700;
            color: #0f172a;
        }

        .click-dot {
            height: 8px;
            width: 8px;
            background: #22c55e;
            border-radius: 50%;
        }

    </style>
</head>

<body>

<div class="main-container">
    <div class="header-section text-center">
        <h1 class="brand-name">SnapLink Pro</h1>
        <p class="text-secondary">Turn long URLs into smart, trackable links.</p>
    </div>

    <div class="premium-card">
     <% if (query && query.id) { %>
    <div class="result-pill">
        Your Short Url is :-
        <a href="http://localhost:8001/<%= query.id %>" class="short-url-text">
            localhost:8001/<%= query.id %>
        </a>
    </div>
<% } %>

        <form method="POST" action="/url">
            <div class="url-input-group">
                <input type="url" name="url" placeholder="Paste your long URL here..." required>
                <button type="submit" class="btn-premium">Shorten</button>
            </div>
        </form>
    </div>

    <% if(locals.urls && urls.length > 0) { %>
        <h5 class="analytics-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3v18h18M7 16l4-4 4 4 5-5"></path></svg>
            Recent Activity
        </h5>
        
        <div class="custom-table shadow-sm">
            <table class="table table-borderless mb-0">
                <thead>
                    <tr>
                        <th>Short ID</th>
                        <th>Destination</th>
                        <th class="text-end">Engagement</th>
                    </tr>
                </thead>
                <tbody>
                    <% urls.forEach((url) => { %>
                        <tr>
                            <td><span class="id-badge"><%= url.shortId %></span></td>
                            <td>
                                <div class="text-truncate" style="max-width: 300px;" title="<%= url.redirectURL %>">
                                    <%= url.redirectURL %>
                                </div>
                            </td>
                            <td class="text-end">
                                <span class="click-count">
                                    <span class="click-dot"></span>
                                    <%= url.visitHistory.length %> <small class="text-muted fw-normal">clicks</small>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

</body>
</html>